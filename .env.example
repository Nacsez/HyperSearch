HYPERSEARCH_ENV=development
HYPERSEARCH_DEBUG=false
HYPERSEARCH_DEBUG_STORE_PROMPTS=false
HYPERSEARCH_HOST=127.0.0.1
HYPERSEARCH_PORT=8000
HYPERSEARCH_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
HYPERSEARCH_LOG_LEVEL=INFO
HYPERSEARCH_SQLITE_PATH=./data/hypersearch.db
HYPERSEARCH_SEARXNG_URL=http://127.0.0.1:8081
HYPERSEARCH_VALKEY_URL=redis://127.0.0.1:6379/0
HYPERSEARCH_LAN_ENABLED=false
HYPERSEARCH_PAIRING_TOKEN=
HYPERSEARCH_LLM_ENABLED=true
HYPERSEARCH_RESEARCH_CAPABILITY=
HYPERSEARCH_CACHE_TTL_SEARCH=120
HYPERSEARCH_CACHE_TTL_PAGE=900
HYPERSEARCH_CACHE_TTL_EXTRACT=1800
HYPERSEARCH_CACHE_TTL_SYNTHESIS=600
HYPERSEARCH_PROVIDER_DEFAULT=lmstudio
HYPERSEARCH_LMSTUDIO_BASE_URL=http://127.0.0.1:1234
HYPERSEARCH_LMSTUDIO_MODEL=qwen2.5-7b-instruct
HYPERSEARCH_VLLM_BASE_URL=
HYPERSEARCH_VLLM_MODEL=
HYPERSEARCH_LLAMACPP_BASE_URL=
HYPERSEARCH_LLAMACPP_MODEL=
HYPERSEARCH_FETCH_TIMEOUT_MS=15000
HYPERSEARCH_PROVIDER_TIMEOUT_MS=180000
HYPERSEARCH_ENABLE_PLAYWRIGHT_FALLBACK=false
HYPERSEARCH_OTEL_ENABLED=false
HYPERSEARCH_MAX_QUERY_LENGTH=500
HYPERSEARCH_MAX_RESULTS_PER_PAGE=50
HYPERSEARCH_MAX_PAGES=5
HYPERSEARCH_MAX_RESEARCH_TOP_N=250
HYPERSEARCH_MAX_TIMEOUT_MS=600000

# Release/container settings used by the Windows desktop launcher and installer.
COMPOSE_PROJECT_NAME=hypersearch
HYPERSEARCH_API_IMAGE=ghcr.io/nacsez/hypersearch-api:1.0.0
HYPERSEARCH_UI_IMAGE=ghcr.io/nacsez/hypersearch-ui:1.0.0
HYPERSEARCH_IMAGE_SOURCE=online
HYPERSEARCH_PRIMARY_REGISTRY=ghcr.io/nacsez
HYPERSEARCH_FALLBACK_REGISTRY=docker.io/nacsez
